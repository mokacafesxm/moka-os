# Boutique Shopify, domaine .myshopify.com (pas le domaine personnalisé)
SHOPIFY_STORE=moka-cafe.myshopify.com

# Identifiants client credentials grant d'une app personnalisée Shopify
# (scopes: read_products). Un access token 24h est échangé automatiquement.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Version de l'API Admin GraphQL (optionnel, défaut: 2026-04)
SHOPIFY_API_VERSION=2026-04

# Token Vercel Blob (accès lecture/écriture)
BLOB_READ_WRITE_TOKEN=

# Token d'intégration interne Notion
NOTION_TOKEN=

# ID de la base Notion "Produits"
NOTION_PRODUCTS_DB_ID=
